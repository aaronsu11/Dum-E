# Default profile
DEEPGRAM_API_KEY=<your-api-key>
ANTHROPIC_API_KEY=<your-api-key>
ELEVENLABS_API_KEY=<your-api-key>

# AWS profile
AWS_ACCESS_KEY_ID=<you_access_key_id>
AWS_SECRET_ACCESS_KEY=<your_secret_access_key>
# Nova-2 Sonic (speech-to-speech) is only available in us-east-1 / us-west-2 / ap-northeast-1 (OQ2)
AWS_REGION=us-east-1

# Deepgram speech backend (D-05). "hosted" (default) uses the hosted Deepgram
# STT/TTS; "sagemaker" uses the Deepgram-on-SageMaker services. The SageMaker
# path is WIRED but the endpoint is NOT deployed this milestone -- selecting it
# without the endpoint names below raises a ValueError (no silent fallback).
# DUME_DEEPGRAM_BACKEND=hosted

# Required ONLY when DUME_DEEPGRAM_BACKEND=sagemaker (both must be set). Names of
# the deployed SageMaker inference endpoints for Deepgram STT / TTS. Leave unset
# on the default hosted path.
# SAGEMAKER_STT_ENDPOINT_NAME=<your-deepgram-stt-sagemaker-endpoint>
# SAGEMAKER_TTS_ENDPOINT_NAME=<your-deepgram-tts-sagemaker-endpoint>

# Optional - for observability
LANGFUSE_SECRET_KEY=<your-api-key>
LANGFUSE_PUBLIC_KEY=<your-api-key>
LANGFUSE_HOST=<your-api-key>
